<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<ScrollPane fitToHeight="true" fitToWidth="true" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gym.ui.gui.ReportsController">

    <VBox spacing="15" VBox.vgrow="ALWAYS">
        <padding>
            <Insets bottom="20" left="20" right="20" top="20" />
        </padding>

        <Label text="Reports and Filters">
            <font>
                <Font name="System Bold" size="18.0" />
            </font>
        </Label>

        <Separator />

        <!-- Report 1: Sessions for a client -->
        <VBox spacing="5">
            <Label style="-fx-font-weight: bold;" text="1. Sessions for a Client:" />
            <HBox spacing="10">
                <TextField fx:id="clientIdField1" prefWidth="100" promptText="Client ID" />
                <Button onAction="#handleSessionsForClient" text="Search Sessions" />
            </HBox>
        </VBox>

        <Separator />

        <!-- Report 2: Phone by client ID -->
        <VBox spacing="5">
            <Label style="-fx-font-weight: bold;" text="2. Find Client's Phone:" />
            <HBox spacing="10">
                <TextField fx:id="clientIdField2" prefWidth="100" promptText="Client ID" />
                <Button onAction="#handlePhoneByClientId" text="Search Phone" />
            </HBox>
        </VBox>

        <Separator />

        <!-- Report 3: Sessions between dates -->
        <VBox spacing="5">
            <Label style="-fx-font-weight: bold;" text="3. Sessions Between Two Dates:" />
            <HBox spacing="10">
                <TextField fx:id="startDateField" prefWidth="200" promptText="Start (yyyy-MM-dd HH:mm)" />
                <TextField fx:id="endDateField" prefWidth="200" promptText="End (yyyy-MM-dd HH:mm)" />
                <Button onAction="#handleSessionsBetween" text="Search" />
            </HBox>
        </VBox>

        <Separator />

        <!-- Report 4: Sessions with keyword -->
        <VBox spacing="5">
            <Label style="-fx-font-weight: bold;" text="4. Sessions with Keyword in Description:" />
            <HBox spacing="10">
                <TextField fx:id="clientIdField4" prefWidth="100" promptText="Client ID" />
                <TextField fx:id="keywordField" prefWidth="150" promptText="Keyword" />
                <Button onAction="#handleSessionsWithKeyword" text="Search" />
            </HBox>
        </VBox>

        <Separator />

        <!-- Report 5: Clients by email domain -->
        <VBox spacing="5">
            <Label style="-fx-font-weight: bold;" text="5. Clients by Email Domain:" />
            <HBox spacing="10">
                <TextField fx:id="domainField" prefWidth="200" promptText="Domain (e.g. @gmail.com)" />
                <Button onAction="#handleClientsByDomain" text="Search" />
            </HBox>
        </VBox>

        <Separator />

        <!-- Filters for Clients -->
        <VBox spacing="5">
            <Label style="-fx-font-weight: bold;" text="6. Filter Clients by Name:" />
            <HBox spacing="10">
                <TextField fx:id="nameFilterField" prefWidth="200" promptText="Name substring" />
                <Button onAction="#handleFilterClientsByName" text="Filter" />
            </HBox>
        </VBox>

        <Separator />

        <VBox spacing="5">
            <Label style="-fx-font-weight: bold;" text="7. Filter Clients by Email Domain:" />
            <HBox spacing="10">
                <TextField fx:id="emailFilterField" prefWidth="200" promptText="Email domain" />
                <Button onAction="#handleFilterClientsByEmail" text="Filter" />
            </HBox>
        </VBox>

        <Separator />

        <!-- Filters for Sessions -->
        <VBox spacing="5">
            <Label style="-fx-font-weight: bold;" text="8. Filter Sessions by Description:" />
            <HBox spacing="10">
                <TextField fx:id="descFilterField" prefWidth="200" promptText="Keyword" />
                <Button onAction="#handleFilterSessionsByDesc" text="Filter" />
            </HBox>
        </VBox>

        <Separator />

        <VBox spacing="5">
            <Label style="-fx-font-weight: bold;" text="9. Filter Sessions After Date:" />
            <HBox spacing="10">
                <TextField fx:id="dateFilterField" prefWidth="200" promptText="Date (yyyy-MM-dd)" />
                <Button onAction="#handleFilterSessionsByDate" text="Filter" />
            </HBox>
        </VBox>

        <Separator />

        <!-- Results area with proper sizing -->
        <VBox spacing="5" VBox.vgrow="ALWAYS">
            <Label style="-fx-font-weight: bold;" text="Results:" />
            <TextArea fx:id="resultsArea" editable="false" minHeight="200" prefHeight="300" style="-fx-font-family: 'Courier New'; -fx-font-size: 12px;" wrapText="true" VBox.vgrow="ALWAYS" />
        </VBox>

    </VBox>

</ScrollPane>
