<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx/11"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="gym.ui.gui.SessionController"
      spacing="10"
      maxWidth="800.0"
      VBox.vgrow="ALWAYS">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20" />
    </padding>

    <Label text="Session Management">
        <font>
            <Font name="System Bold" size="18.0" />
        </font>
    </Label>

    <Separator/>

    <!-- Session table -->
    <TableView fx:id="sessionTable" VBox.vgrow="ALWAYS" prefHeight="300">
        <columns>
            <TableColumn fx:id="idColumn" text="ID" prefWidth="50"/>
            <TableColumn fx:id="clientIdColumn" text="Client ID" prefWidth="80"/>
            <TableColumn fx:id="dateTimeColumn" text="Date/Time" prefWidth="150"/>
            <TableColumn fx:id="descriptionColumn" text="Description" prefWidth="250"/>
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>

    <Label text="Session Details:"/>

    <!-- Input fields -->
    <GridPane hgap="10" vgap="10">
        <columnConstraints>
            <ColumnConstraints percentWidth="20"/>
            <ColumnConstraints percentWidth="20"/>
            <ColumnConstraints percentWidth="30"/>
            <ColumnConstraints percentWidth="30"/>
        </columnConstraints>

        <TextField fx:id="idField" promptText="ID" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <TextField fx:id="clientIdField" promptText="Client ID" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
        <TextField fx:id="dateTimeField" promptText="Date (yyyy-MM-dd HH:mm)" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
        <TextField fx:id="descriptionField" promptText="Description" GridPane.columnIndex="3" GridPane.rowIndex="0"/>
    </GridPane>

    <!-- Action buttons -->
    <HBox spacing="10">
        <Button text="Add" onAction="#handleAddSession" prefWidth="80"/>
        <Button text="Update" onAction="#handleUpdateSession" prefWidth="80"/>
        <Button text="Delete" onAction="#handleDeleteSession" prefWidth="80"/>
    </HBox>

    <Label style="-fx-font-style: italic;"
           text="Date format: yyyy-MM-dd HH:mm (example: 2024-12-03 14:30)"/>

</VBox>